# ClaimLink Frontend Environment Variables Example
# Copy this file to .env.local, .env.staging, or .env.production and update values

# Backend Canister IDs
VITE_CLAIMLINK_CANISTER_ID=your-claimlink-canister-id
VITE_NFT_CANISTER_ID=your-nft-canister-id
VITE_CERTIFICATE_CANISTER_ID=your-certificate-canister-id

# OGY Ledger Canister ID
VITE_LEDGER_CANISTER_ID=your-ogy-ledger-canister-id

# IC Network Host
# Local: http://localhost:4943 (must match dfx.json and ORIGYN NFT test_mode URLs)
# Staging: https://icp0.io
# Production: https://icp0.io
VITE_IC_HOST=https://icp0.io

# NFID Configuration (localhost development only)
# Only needed when running against local replica
VITE_NFID_LOCALHOST_TARGETS=http://localhost:5173,http://localhost:4943
VITE_NFID_DERIVATION_ORIGIN=http://localhost:5173

# Optional: Swap Canister ID (if using swap functionality)
# VITE_SWAP_CANISTER_ID=your-swap-canister-id
