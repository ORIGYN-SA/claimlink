{
  "__0": "ORIGYN Claimlink Monorepo",
  "canisters": {
   
    "ogy_ledger": {
      "type": "custom",
      "candid": "backend/external_canisters/icrc_ledger/api/can.did",
      "wasm": "backend/external_canisters/icrc_ledger/wasm/icrc_ledger_canister.wasm.gz",
      "declarations": {
        "bindings": ["js", "did", "ts"],
        "env_override": null,
        "output": "backend/external_canisters/icrc_ledger/api/declarations"
      }
    },
    "claimlink_backend": {
      "type": "custom",
      "candid": "backend/canisters/claimlink/api/can.did",
      "package": "claimlink_backend",
      "wasm": "backend/canisters/claimlink/target/wasm32-unknown-unknown/release/claimlink_canister.wasm.gz",
      "declarations": {
        "bindings": ["js", "did", "ts"],
        "env_override": null,
        "output": "backend/canisters/claimlink/api/declarations"
      },
       "metadata": [
        {
          "name": "candid:service"
        }
      ]
    },
    "claimlink_frontend": {
      "declarations": {
        "bindings": [],
        "env_override": null,
        "output": null
      },
      "source": ["frontend/claimlink_dashboard/dist"],
      "type": "assets"
    }
  },
  "dfx": "0.29.0",
  "networks": {
    "staging": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    },
    "preprod": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    },
    "local": {
      "bind": "localhost:4943",
      "type": "ephemeral"
    }
  }
}
